{
  "buildCommand": "vite build && esbuild server/index.ts --platform=node --bundle --format=esm --outfile=api/index.js '--define:process.env.NODE_ENV=\"production\"'",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
